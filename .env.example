# Netlify / Neon
# Do NOT commit real values. Put real values in Netlify Environment Variables.
NETLIFY_DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"
NP_JWT_SECRET="replace-with-a-long-random-secret-of-at-least-32-characters"

# Optional
NP_SITE_URL="https://your-site.netlify.app"
NP_ADMIN_PSEUDO="Admin"
NP_ADMIN_PASSWORD="replace-with-a-temporary-admin-password"
